name: basic_cleaning
conda_env: conda.yml

entry_points:
  main:
    parameters:
      input_artifact:
        description: Input artifact name
        type: str
      output_name:
        description: Output artifact name
        type: str
      output_type:
        description: Output artifact type
        type: str
      output_description:
        description: Output artifact description
        type: str
      min_price:
        description: Minimum price to consider
        type: float
      max_price:
        description: Maximum price to consider
        type: float
    command: "python run.py --input_artifact {input_artifact} --output_name {output_name} --output_type {output_type} --output_description {output_description} --min_price {min_price} --max_price {max_price}"
